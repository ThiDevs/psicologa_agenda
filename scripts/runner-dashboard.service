[Unit]
Description=Painel de Monitoramento do GitHub Runner
After=network.target

[Service]
Type=simple
User=prod
WorkingDirectory=/home/prod/.gemini/antigravity/scratch/psi-agenda
ExecStart=/usr/bin/python3 scripts/dashboard_server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
