# Configuration template for production
# Copy this file to .env.prod on the server and update the values.
# NEVER commit the actual .env.prod file to Git.

POSTGRES_DB=psi_agenda
POSTGRES_USER=psi_agenda
POSTGRES_PASSWORD=change-to-a-very-strong-password-here

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# Connection string using the postgres service name defined in docker-compose.prod.yml
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=psi_agenda;Username=psi_agenda;Password=change-to-a-very-strong-password-here

Jwt__Issuer=psi-agenda-api
Jwt__Audience=psi-agenda-app
Jwt__SigningKey=change-to-a-very-strong-key-with-at-least-32-characters

BusinessClock__TimeZoneId=America/Sao_Paulo
BusinessClock__UtcOffset=-03:00
